# ---------------------------------------------------------------
# Supabase project (B2BB2G)
# Dashboard: https://supabase.com/dashboard/project/ruzamxdsuddjjuqmxokf
# ---------------------------------------------------------------

# Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
# Settings -> API Keys: "anon public" or a key starting with sb_publishable_
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Settings -> Database -> Database password.
# Server/CLI only (no NEXT_PUBLIC_ prefix, never shipped to the browser).
# Used to apply supabase/migrations/*.sql with psql.
SUPABASE_DB_PASSWORD=

# ---------------------------------------------------------------
# Resend (transactional email, PRD 10.2 / 15)
# Dashboard: https://resend.com/api-keys
# The same API key is also used in Supabase dashboard SMTP settings
# (Authentication -> Emails -> SMTP: host smtp.resend.com, port 465,
#  username "resend", password = this API key) for auth emails.
# ---------------------------------------------------------------

# Server only. App notification emails are skipped when empty.
RESEND_API_KEY=
# Sender must belong to a domain verified in Resend (SPF/DKIM records).
# Production: no-reply@b2bb2g.com
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=B2BB2G

# ---------------------------------------------------------------
# Deployment
# ---------------------------------------------------------------

# hCaptcha site key (public). Widget shows on auth forms when set; enable
# Supabase Attack Protection captcha ONLY after this is deployed.
# NOTE: hCaptcha does not support localhost. For local dev, add
#   127.0.0.1 dev.b2bb2g.com   to /etc/hosts, register dev.b2bb2g.com in the
# hCaptcha dashboard hostnames, and browse http://dev.b2bb2g.com:3000.
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=

# Absolute URL of this deployment (referral links, auth redirect emails).
# Local: http://localhost:3000 / Production (Vercel + main domain): https://b2bb2g.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------------------------------------------------------------
# Web push (PWA notifications)
# Generate a pair once with: npx web-push generate-vapid-keys
# ---------------------------------------------------------------

# Public half, shipped to the browser for PushManager.subscribe.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# Server only: signs push messages.
VAPID_PRIVATE_KEY=
# Contact for push services, mailto: form.
VAPID_SUBJECT=mailto:badaon.com@gmail.com

# Server only. Settings -> API Keys: "service_role" (or sb_secret_ key).
# Used exclusively by /api/push/dispatch to read the notification row and the
# recipient's push subscriptions. Never expose with a NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=
